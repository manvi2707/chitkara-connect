# ── Server ────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chitkara-connect

# ── JWT ───────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# ── Cloudinary (photo uploads) ────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Groq AI (chatbot) ─────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here

# ── Frontend URL (CORS) ───────────────────────
CLIENT_URL=http://localhost:3000

# ── Email Notifications (optional but recommended) ──────
# Uses Gmail + App Password (NOT your regular Gmail password)
#
# How to set up:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → Generate one for "Mail"
#   4. Paste the 16-char code below (with spaces is fine)
#
# If these are left blank, the app still works —
# emails are simply skipped without any errors.
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
